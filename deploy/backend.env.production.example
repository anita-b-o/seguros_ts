# Production environment variables for Django (securests.com)
# Copy to /etc/securests/backend.env and replace placeholders.

# --- Core ---
DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SKIP_DOTENV=true
DJANGO_SECRET_KEY=changeme-rotate-in-prod
DJANGO_ALLOWED_HOSTS=securests.com,www.securests.com
ADMIN_URL=admin/

# --- CORS / CSRF (same site) ---
FRONTEND_ORIGINS=https://securests.com,https://www.securests.com
FRONTEND_ORIGIN=https://securests.com
CORS_ALLOWED_ORIGINS=https://securests.com,https://www.securests.com
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_ALL_ORIGINS=false

# --- Database (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=securests
DB_USER=securests
DB_PASSWORD=changeme
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Cache / Redis ---
REDIS_URL=redis://127.0.0.1:6379/1
RUN_REDIS_HEALTHCHECK=false

# --- OTP / rate limits ---
OTP_PEPPER=changeme-pepper
OTP_TIMEOUT_SECONDS=600
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_SEND_COUNT=5
OTP_RATE_LIMIT_SEND_WINDOW=600
OTP_RATE_LIMIT_VERIFY_COUNT=10
OTP_RATE_LIMIT_VERIFY_WINDOW=600

# --- API throttling ---
API_PAGE_SIZE=10
API_MAX_PAGE_SIZE=500
API_THROTTLE_ANON=60/hour
API_THROTTLE_USER=120/hour
API_THROTTLE_QUOTES=10/hour
API_THROTTLE_LOGIN=20/hour
API_THROTTLE_RESET=10/hour
API_THROTTLE_REGISTER=30/hour
API_THROTTLE_CLAIM=15/hour
API_ALLOW_ANY_IN_DEBUG=false

# --- JWT ---
JWT_ACCESS_HOURS=8
JWT_REFRESH_DAYS=7
JWT_ALGORITHM=HS256
# If unset, JWT_SIGNING_KEY defaults to SECRET_KEY
JWT_SIGNING_KEY=
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Lax
# Optional if you want cookies shared across subdomains
JWT_COOKIE_DOMAIN=.securests.com

# --- Mercado Pago ---
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_ALLOW_WEBHOOK_NO_SECRET=false
MP_ALLOW_FAKE_PREFERENCES=false
MP_NOTIFICATION_URL=https://securests.com/api/payments/webhook

# --- Media / uploads ---
MEDIA_URL=/media/
MEDIA_ROOT=/srv/securests/app/backend/media
MEDIA_MAX_UPLOAD_MB=10
SERVE_MEDIA_FILES=false
ALLOW_SERVE_MEDIA_IN_PROD=false
RECEIPT_DEBUG_GRID=false
RECEIPT_TEMPLATE_PDF=/srv/securests/app/backend/static/receipts/COMPROBANTE.pdf

# --- Email ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=no-reply@securests.com
ALLOW_CONSOLE_EMAIL_IN_PROD=false

# --- Logging / security ---
LOG_LEVEL=INFO
ALLOW_METRICS_PUBLIC=false
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=15552000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false
