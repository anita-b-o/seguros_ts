# Backup ops config (copy to /etc/securests/backup-ops.env)

# Local backup settings
ENV_FILE=/etc/securests/backend.env
OUT_DIR=/srv/securests/backups/prod
RETENTION_DAYS=14
SKIP_MEDIA=false

# Offsite sync (rsync over SSH)
# Example target: backup@backup-host:/data/securests-backups
OFFSITE_ENABLED=false
OFFSITE_RSYNC_TARGET=
OFFSITE_RSYNC_OPTS="-az --partial --chmod=F600,D700"
# Example: -i /home/deploy/.ssh/id_backup -o StrictHostKeyChecking=yes
OFFSITE_SSH_OPTS=

# Periodic restore verification
MAX_BACKUP_AGE_HOURS=36
RESTORE_TEST_ENABLED=true
RESTORE_TEST_TIMEOUT_SECONDS=600
